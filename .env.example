# TURN Server Configuration
# これらの値は絶対にGitにコミットしないこと！

# TURNサーバーのURL（IPアドレスまたはドメイン）
TURN_SERVER_URL=your-turn-server.com

# TURN認証用ユーザー名
TURN_USERNAME=your-username

# TURN認証用パスワード
TURN_CREDENTIAL=your-password

# 例（Meteredの場合）:
# TURN_SERVER_URL=a.relay.metered.ca
# TURN_USERNAME=85a6f8b5d3e6c9d8f7e6d5c4
# TURN_CREDENTIAL=password123
